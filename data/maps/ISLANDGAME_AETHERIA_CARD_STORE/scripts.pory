const FLAG_DAYTIME = FLAG_TEMP_2
const FLAG_NIGHTTIME = FLAG_TEMP_3

mapscripts ISLANDGAME_AETHERIA_CARD_STORE_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        if (gettimeofday == TIME_NIGHT) {
            setflag(FLAG_NIGHTTIME)
        }
        else {
            setflag(FLAG_DAYTIME)
        }
    }
}

// Signs
script ISLANDGAME_AETHERIA_CARD_STORE_Binder {
    msgbox(format(
        "{COLOR RED}(It's a trade binder full of rare cards.)\p"
        "(It's mostly comprised of different Pikachu, Charizard, and Greninja cards.)"
    ), MSGBOX_SIGN)
}

script ISLANDGAME_AETHERIA_CARD_STORE_Board {
    msgbox(format(
        "{COLOR RED}(It's a schedule detailing all of the upcoming events for this month.)"
    ), MSGBOX_SIGN)
}





// NPCs
script ISLANDGAME_AETHERIA_CARD_STORE_SaltyPlayer {
    lock
    msgbox(format(
        "Woooow, who could've guessed, another lame Crustle player ruining the game for everyone as usual.\p"
        "Can they just ban that card already? Like are we for real, man? It's just not fair anymore dude like I can't do anything about it.\p"
        "I didn't pay ¥15000 just to lose to some kid with his degenerate no-skill stun deck!"
    ), MSGBOX_AUTOCLOSE)
}

script ISLANDGAME_AETHERIA_CARD_STORE_LittleCamper {
    lock
    msgbox(format(
        "Ummmmm, good game...?"
    ), MSGBOX_AUTOCLOSE)
}

script ISLANDGAME_AETHERIA_CARD_STORE_Nerd {
    lock
    msgbox(format(
        "You know... if you're looking to get better, we could continue playing at my place...\p"
        "I'd be happy to teach you some deckbuilding quantum mechanics..."
    ), MSGBOX_AUTOCLOSE)
}

script ISLANDGAME_AETHERIA_CARD_STORE_Girl {
    lock
    msgbox(format(
        "Eeeeeh..."
    ), MSGBOX_AUTOCLOSE)
}

script ISLANDGAME_AETHERIA_CARD_STORE_AlakazamPlayer {
    lock
    msgbox(format(
        "Evolve Abra into Kadabra. Use Kadabra ability to draw 2 cards. Evolve Dunsparce into Dudunsparce. Attach Enriching Energy to Dudunsparce to draw 4 cards.\p"
        "Use Dudunsparce ability, draw 3 cards and shuffle back. Play Poké Pad to add Alakazam. Use Rare Candy to evolve Abra into Alakazam. Use Alakazam ability to draw 3 cards.\p"
        "Use Wondrous Patch to attach a Psychic Energy to Alakazam. Use my other Dudunsparce ability to draw 3 cards and shuffle it back. Use Fezandipiti ability to draw 3 more cards..."
    ), MSGBOX_AUTOCLOSE)
}

script ISLANDGAME_AETHERIA_CARD_STORE_Whiner {
    lock
    msgbox(format(
        "DOES YOUR TURN HAVE AN END!?"
    ), MSGBOX_AUTOCLOSE)

}

script ISLANDGAME_AETHERIA_CARD_STORE_Bye {
    lock
    faceplayer
    msgbox(format(
        "We have an uneven amount of players in the tournament, so I got a bye for the first round."
    ))
}

script ISLANDGAME_AETHERIA_CARD_STORE_Owner {
    lock
    faceplayer
    if (gettimeofday == TIME_NIGHT) {
        msgbox(format(
            "Welcome to The Top Deck!\p"
            "Unfortunately, our PTCG tournament has already started, but you're more than welcome to spectate!"
        ), MSGBOX_AUTOCLOSE) 
    }
    else {
        if(!flag(FLAG_AETHERIA_RED_CARD)) {
            msgbox(format(
                "Welcome to The Top Deck!\p"
                "If you're looking for packs of the newest expansion, I regret to inform you that we just ran out...\p"
                "Due to complications with the distributor, I'm not sure when we'll get more of it.\p"
                "In the meantime, please accept this promotional card as apologies for the inconvenience."
            ))
            giveitem(ITEM_RED_CARD)
        }
        else {
            msgbox(format(
                "That right there is a special holographic Red Card!\p"
                "Not only is it a powerful card in the TCG, but it is also quite useful in Pokémon battles as well!\p"
                "We're hoping to get at least another wave of Maryan Masters before the festival, so be sure to visit our booth for another chance!"
            ))
        }
    }
}

script ISLANDGAME_AETHERIA_CARD_STORE_Assistant {
    lock
    faceplayer
    msgbox(format(
        "As the judge, it's my job to handle any ruling disputes players may have during the course of a match.\p"
        "It is also my job to diffuse any hostile situations that might arise during the tournament... which I have had to do a couple of times.\p"
        "Card games are serious business."
    ), MSGBOX_AUTOCLOSE)
}

script ISLANDGAME_AETHERIA_CARD_STORE_InvestorBro {
    lock
    msgbox(format(
        "This purchase limit is an OUTRAGE!\p"
        "Why should I be punished for being successful enough to have the funds to purchase a case of the newest set!?\p"
        "Need I remind you that I alone pay for your store's rent each month!?\p"
        "I will not tolerate this disrespect of my affluence!"
    ), MSGBOX_AUTOCLOSE)
}

script ISLANDGAME_AETHERIA_CARD_STORE_Scalper {
