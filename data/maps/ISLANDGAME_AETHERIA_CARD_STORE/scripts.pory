    msgbox(format(
        "Yeah, right! My hands were on it first! It belongs to me!"
    ), MSGBOX_AUTOCLOSE)
}

script ISLANDGAME_AETHERIA_CARD_STORE_Puller {
    lock
    msgbox(format(
        "C'mon...{PAUSE 30} C'mon...{PAUSE 30} heart of the cards... guide me!!!\p"
